# ClipForge — required environment variables
# Copy this file to .env (gitignored) and fill in the keys you have.
# Missing keys degrade gracefully (e.g. Whisper instead of Deepgram).

# Transcription
DEEPGRAM_API_KEY=

# Stock B-roll
PEXELS_API_KEY=

# Optional RNNoise/arnndn model override for /clip-forge:enhance.
# Leave empty to use the pinned cb.rnnn URL in bin/install-models.mjs.
CF_RNNOISE_MODEL_URL=

# ---- v0.4.0 Tier 2 BYO keys — all optional, every feature degrades to
# ----                       local-only behavior (Piper TTS fallback)
# TTS provider precedence: elevenlabs → cartesia → groq → piper (local).
# Set CF_TTS_PROVIDER=<name> to force a specific provider.
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
GROQ_API_KEY=
CF_TTS_PROVIDER=
# Cumulative AI-spend cap across the skill chain (default $10).
CF_AI_BUDGET_USD=

# LLM provider for /clip-forge:edit prompt mode + translate fallback.
# Precedence: GROQ_API_KEY → ANTHROPIC_API_KEY. Override with CF_LLM_PROVIDER.
ANTHROPIC_API_KEY=
CF_LLM_PROVIDER=
# Force translate provider for /clip-forge:dub (mirrors CF_LLM_PROVIDER shape).
CF_TRANSLATE_PROVIDER=

# TikTok publishing
# https://developers.tiktok.com → Apps → Manage apps → keys
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube Shorts publishing
# https://console.cloud.google.com → APIs → YouTube Data API v3 → OAuth client
YT_CLIENT_ID=
YT_CLIENT_SECRET=

# Instagram Reels publishing (Meta Graph API)
# https://developers.facebook.com → My Apps → Instagram Graph API
IG_APP_ID=
IG_APP_SECRET=
