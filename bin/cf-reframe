#!/usr/bin/env node
// cf-reframe — generates a crop path JSON for converting 16:9 → 9:16 (or any
// portrait/square aspect ratio).
//
// Pipeline:
//   ffmpeg pipe rgb24 → face-detector (MediaPipe) → active-speaker scorer
//     → Kalman smoother (untouched from v0.1.0) → velocity clamp (untouched)
//     → crop_path.json (schema v2, backward-compatible with cf-ffmpeg)
//
// Graceful degradation: every failure mode (model missing, MediaPipe import
// fail, detector crash, all-frames-no-face) falls through to center-crop and
// records the reason in the output metadata. Exit code 0 in all cases except
// invalid CLI args — the renderer must never break because reframe couldn't
// detect faces.
//
// CLI:
//   cf-reframe <source.mp4> --output <crop.json>
//   cf-reframe --in <source.mp4> --out <crop.json>   (v0.1.0 form, still works)
//
// See --help for the full flag list.

import { spawnSync } from 'node:child_process';
import { writeFileSync, mkdirSync, readFileSync, existsSync } from 'node:fs';
import { dirname, resolve as resolvePath } from 'node:path';

import { extractFrames } from './lib/frame-extractor.mjs';
import {
  initDetector, detectFaces, closeDetector, isDetectorReady, getDisabledReason,
  getDetectorProvider, getDetectorProviderFallbackReason,
} from './lib/face-detector.mjs';
import {
  initLandmarker, detectLandmarks, closeLandmarker, isLandmarkerReady, getLandmarkerReason,
  getLandmarkerProvider, getLandmarkerProviderFallbackReason,
} from './lib/landmark-detector.mjs';
import { ActiveSpeakerTracker, parseSpeakerMap, autoCalibrateSpeakerMap } from './lib/active-speaker.mjs';
import { writeDebugPpm } from './lib/debug-frame.mjs';

const TARGET_H_DEFAULT = 1920;

function parseArgs(argv) {
  const out = {
    in: null,
    out: null,
    startMs: null,
    endMs: null,
    mode: 'face',
    fps: 6,
    maxPanPxS: 80,
    targetAspect: '9:16',
    minConfidence: 0.5,
    weights: null,           // null → defaults in ActiveSpeakerTracker
    noActiveSpeaker: false,
    fallbackMode: 'center',  // center | topcrop
    debug: false,
    jsonLogs: false,
    speakerMap: null,        // raw string; parsed later
    transcript: null,        // path
  };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--help' || a === '-h') { printHelp(); process.exit(0); }
    else if (a === '--in')                out.in = argv[++i];
    else if (a === '--out')               out.out = argv[++i];
    else if (a === '--output')            out.out = argv[++i];
    else if (a === '--start-ms')          out.startMs = parseInt(argv[++i], 10);
    else if (a === '--end-ms')            out.endMs   = parseInt(argv[++i], 10);
    else if (a === '--mode')              out.mode    = argv[++i];
    else if (a === '--fps')               out.fps     = parseFloat(argv[++i]);
    else if (a === '--sample-fps')        out.fps     = parseFloat(argv[++i]);
    else if (a === '--max-pan-px-s')      out.maxPanPxS = parseFloat(argv[++i]);
    else if (a === '--target-aspect')     out.targetAspect = argv[++i];
    else if (a === '--min-confidence')    out.minConfidence = parseFloat(argv[++i]);
    else if (a === '--weights')           out.weights = parseWeights(argv[++i]);
    else if (a === '--no-active-speaker') out.noActiveSpeaker = true;
    else if (a === '--fallback')          out.fallbackMode = argv[++i];
    else if (a === '--debug')             out.debug = true;
    else if (a === '--json-logs')         out.jsonLogs = true;
    else if (a === '--speaker-map')       out.speakerMap = argv[++i];
    else if (a === '--transcript')        out.transcript = argv[++i];
    else if (!a.startsWith('--') && !out.in) out.in = a; // positional source
    else die('unknown flag: ' + a);
  }
  return out;
}

function parseWeights(spec) {
  const parts = spec.split(',').map((s) => parseFloat(s.trim()));
  if (parts.length !== 4 || parts.some((n) => Number.isNaN(n))) {
    die('--weights expects 4 comma-separated floats: audio,mouth,central,confidence');
  }
  return { audio: parts[0], mouth: parts[1], central: parts[2], confidence: parts[3] };
}

function parseAspect(spec) {
  const m = String(spec || '').match(/^(\d+):(\d+)$/);
  if (!m) die('--target-aspect must be W:H (got ' + spec + ')');
  return { w: parseInt(m[1], 10), h: parseInt(m[2], 10) };
}

function die(msg, code = 1) {
  process.stderr.write('cf-reframe: ' + msg + '\n');
  process.exit(code);
}

function printHelp() {
  process.stdout.write(`cf-reframe — 16:9 → 9:16 face-tracked crop path generator

usage:
  cf-reframe <source.mp4> --output <crop.json> [flags]
  cf-reframe --in <source.mp4> --out <crop.json> [flags]    (v0.1.0 form)

source flags:
  --start-ms N              clip start in source ms (default: 0)
  --end-ms N                clip end in source ms (default: full duration)
  --target-aspect W:H       output aspect (default: 9:16)

detection flags:
  --mode face|object|center default: face
  --sample-fps N            detect at N fps (default: 6)
  --min-confidence 0..1     reject detections below this (default: 0.5)
  --weights a,m,c,k         audio,mouth,central,confidence (default: 0.3,0.5,0.1,0.1)
  --no-active-speaker       pick highest-confidence face only
  --speaker-map <spec>      'auto' | '0:left,1:right' | '0:0.25,0.5,1:0.75,0.5'
  --transcript <path>       transcript.json (enables audio cue)

smoothing flags:
  --max-pan-px-s N          velocity clamp (default: 80 src px/s)

fallback flags:
  --fallback center|topcrop default: center

output flags:
  --output <path>           crop_path.json output (default: ./crop_path.json)
  --debug                   write ./debug/frame-NNNN.ppm every 30 frames with overlay
  --json-logs               NDJSON progress on stdout (one line per processed frame)

examples:
  cf-reframe ./uploads/podcast/source.mp4 --output ./crop.json
  cf-reframe ./src.mp4 --output ./crop.json --speaker-map auto --transcript ./tx.json
  cf-reframe ./src.mp4 --output ./crop.json --weights 0.4,0.4,0.1,0.1 --debug
`);
}

function probe(file) {
  const r = spawnSync('ffprobe', ['-v', 'error', '-print_format', 'json',
                                   '-show_streams', '-show_format', file]);
  if (r.status !== 0) return null;
  try {
    const data = JSON.parse(r.stdout.toString());
    const v = (data.streams || []).find((s) => s.codec_type === 'video') || {};
    const fmt = data.format || {};
    return {
      width: v.width || 0,
      height: v.height || 0,
      duration_ms: Math.round((parseFloat(fmt.duration || 0) || 0) * 1000),
    };
  } catch { return null; }
}

function clampVelocity(samples, maxPanPxS) {
  if (samples.length < 2) return samples;
  for (let i = 1; i < samples.length; i++) {
    const prev = samples[i - 1];
    const cur = samples[i];
    const dt = (cur.t_ms - prev.t_ms) / 1000;
    if (dt <= 0) continue;
    const maxDx = maxPanPxS * dt;
    const dx = cur.cx - prev.cx;
    if (Math.abs(dx) > maxDx) cur.cx = prev.cx + Math.sign(dx) * maxDx;
    const dy = cur.cy - prev.cy;
    const maxDy = maxPanPxS * dt;
    if (Math.abs(dy) > maxDy) cur.cy = prev.cy + Math.sign(dy) * maxDy;
  }
  return samples;
}

function kalman1d(values, q = 1e-3, r = 1e-1) {
  // Simple 1D Kalman smoother — UNCHANGED from v0.1.0.
  const out = new Array(values.length);
  let x = values[0]; let p = 1;
  for (let i = 0; i < values.length; i++) {
    p = p + q;
    const k = p / (p + r);
    x = x + k * (values[i] - x);
    p = (1 - k) * p;
    out[i] = x;
  }
  return out;
}

function fallbackSamples(opts, srcW, srcH, targetW, targetH, reason) {
  const scaleHFit = srcH / targetH;
  const stepMs = Math.max(50, Math.round(1000 / opts.fps));
  const samples = [];
  // For 'topcrop', vertical center is shifted up (face usually in upper third).
  const cy = opts.fallbackMode === 'topcrop' ? Math.floor(srcH * 0.38) : Math.floor(srcH / 2);
  for (let t = 0; t <= (opts.endMs - opts.startMs); t += stepMs) {
    samples.push({ t_ms: t, cx: Math.floor(srcW / 2), cy,
                   scale: +scaleHFit.toFixed(3), letterbox: false });
  }
  return { samples, reason };
}

function jlog(opts, obj) {
  if (opts.jsonLogs) process.stdout.write(JSON.stringify({ ts: Date.now(), ...obj }) + '\n');
}

async function collectLeadIn(opts) {
  // Run detection over the first 5s (capped to clip duration) for auto-calibration.
  const leadEnd = Math.min(opts.endMs, opts.startMs + 5000);
  const samples = [];
  for await (const frame of extractFrames({
    input: opts.in,
    sampleFps: Math.max(opts.fps, 8), // higher sample rate during calibration
    startMs: opts.startMs,
    endMs: leadEnd,
  })) {
    let faces = [];
    try {
      faces = await detectFaces(frame.rgb, frame.width, frame.height, frame.tMs,
                                frame.sourceWidth, frame.sourceHeight);
    } catch { /* ignore per-frame */ }
    samples.push({ tMs: frame.tMs, faces });
  }
  return samples;
}

async function detectPath(opts, srcW, srcH, targetW, targetH) {
  // Parse the speaker map + transcript BEFORE initializing the detector so
  // an early bail (detector unavailable, model missing) still carries this
  // metadata through to the output — proves the flag was honored even when
  // we couldn't run real detection.
  let speakerMap = null;
  let transcript = null;
  let speakerMapWantsAuto = false;
  if (opts.transcript) {
    try { transcript = JSON.parse(readFileSync(opts.transcript, 'utf-8')); }
    catch (e) { jlog(opts, { event: 'warn', msg: 'transcript_load_failed: ' + e.message }); }
  }
  if (opts.speakerMap && transcript) {
    const parsed = parseSpeakerMap(opts.speakerMap);
    if (parsed === 'auto')      speakerMapWantsAuto = true;
    else if (parsed)            speakerMap = parsed;
  }

  await initDetector({ minConfidence: opts.minConfidence });
  if (!isDetectorReady()) {
    return { samples: null, reason: 'detector_unavailable: ' + (getDisabledReason() || 'unknown'),
             speakerMap };
  }
  const detectorProvider = getDetectorProvider();
  const detectorProviderFallbackReason = getDetectorProviderFallbackReason();
  // Pre-warm the landmarker so the frame-budget heuristic below sees its
  // readiness state before the loop starts. Lazy-init inside the loop would
  // race the budget check on the first frame.
  await initLandmarker({});
  const landmarkerProvider = getLandmarkerProvider();
  const landmarkerProviderFallbackReason = getLandmarkerProviderFallbackReason();
  if (!isLandmarkerReady()) {
    jlog(opts, { event: 'warn', msg: 'landmarker_unavailable: ' + (getLandmarkerReason() || 'unknown') + ' — proceeding without 68-pt keypoints' });
  }

  if (speakerMapWantsAuto) {
    jlog(opts, { event: 'calibration_start' });
    const lead = await collectLeadIn(opts);
    speakerMap = autoCalibrateSpeakerMap(lead, transcript, srcW, srcH);
    jlog(opts, { event: 'calibration_done', map: speakerMap });
  }

  const tracker = new ActiveSpeakerTracker({
    weights: opts.weights || undefined,
    disableActiveSpeaker: opts.noActiveSpeaker,
    transcript,
    speakerMap,
  });

  if (opts.debug) mkdirSync('./debug', { recursive: true });

  // Soft per-frame budget. v0.1.x was sized for face detection only (200ms);
  // v0.2.0 chains detection → PFLD landmark on each face, so the realistic
  // ceiling is higher. We bump to 1000ms when the landmarker is loaded so
  // the cooldown doesn't fire on every frame and starve the pipeline.
  const FRAME_BUDGET_MS = isLandmarkerReady() ? 1000 : 200;
  const raw = [];
  let framesProcessed = 0;
  let framesWithFace = 0;
  let framesSlow = 0;
  let lastGood = null;
  let lastDebugFrame = -30;
  let skipDetectFor = 0; // cooldown: skip detect on next N frames after a slow one

  // Phase 2E diagnostics — surface enough state for the success-path test to
  // distinguish a real face-tracked render from a silent fallback regression.
  let prevFaceId = null;
  let trackerFlips = 0;
  let samplesWithKeypoints = 0;
  const mouthYs = [];
  let totalLandmarksPerFace = 0; // sampled on the first frame that has them; should be 68 for PFLD-68

  let extractorOk = true;
  let extractorErr = null;

  try {
    for await (const frame of extractFrames({
      input: opts.in,
      sampleFps: opts.fps,
      startMs: opts.startMs,
      endMs: opts.endMs,
    })) {
      framesProcessed++;
      let faces = [];
      let elapsed = 0;
      if (skipDetectFor > 0) {
        skipDetectFor--;
        // Pretend no face detected; rely on last-known-good.
      } else {
        const t0 = Date.now();
        try {
          faces = await detectFaces(frame.rgb, frame.width, frame.height, frame.tMs,
                                    frame.sourceWidth, frame.sourceHeight);
          // Phase 2B: augment each face with PFLD 68-point landmarks (lazy init).
          if (faces.length > 0) {
            if (!isLandmarkerReady() && !getLandmarkerReason()) {
              await initLandmarker({});
            }
            if (isLandmarkerReady()) {
              const augmented = [];
              for (const f of faces) {
                augmented.push(await detectLandmarks(f, frame.rgb, frame.width, frame.height,
                                                     frame.sourceWidth, frame.sourceHeight));
              }
              faces = augmented;
            }
          }
        } catch (e) {
          faces = [];
          jlog(opts, { event: 'frame_detect_threw', t_ms: frame.tMs, error: e.message });
        }
        elapsed = Date.now() - t0;
        if (elapsed > FRAME_BUDGET_MS) {
          framesSlow++;
          skipDetectFor = Math.min(4, Math.ceil(elapsed / FRAME_BUDGET_MS));
          jlog(opts, { event: 'frame_over_budget', t_ms: frame.tMs, elapsed_ms: elapsed, skip_next: skipDetectFor });
        }
      }

      const ctx = { tMs: frame.tMs, frameWidth: frame.sourceWidth, frameHeight: frame.sourceHeight };
      const pick = tracker.pickActiveFace(faces, ctx);

    if (pick.face) {
      framesWithFace++;
      lastGood = { cx: pick.face.x, cy: pick.face.y };
      raw.push({ t_ms: frame.tMs, cx: pick.face.x, cy: pick.face.y });

      // Diagnostics: count tracker-id flips between consecutive face-bearing frames.
      if (prevFaceId != null && pick.faceId != null && pick.faceId !== prevFaceId) {
        trackerFlips++;
      }
      prevFaceId = pick.faceId;

      // Diagnostics: keypoint coverage + mouth_y series (for stddev assertion).
      const kp = pick.face.keypoints;
      if (kp && kp.all && kp.all.length > 0) {
        samplesWithKeypoints++;
        if (totalLandmarksPerFace === 0) totalLandmarksPerFace = kp.all.length;
        if (kp.mouth && typeof kp.mouth.y === 'number') mouthYs.push(kp.mouth.y);
      }
    } else if (lastGood) {
      raw.push({ t_ms: frame.tMs, cx: lastGood.cx, cy: lastGood.cy });
    } else {
      raw.push({ t_ms: frame.tMs, cx: srcW / 2, cy: srcH / 2 });
    }

    if (opts.debug && frame.frameIdx - lastDebugFrame >= 30) {
      lastDebugFrame = frame.frameIdx;
      const idxStr = String(frame.frameIdx).padStart(5, '0');
      try {
        writeDebugPpm(frame.rgb, frame.width, frame.height, pick.face,
                      './debug/frame-' + idxStr + '.ppm',
                      { sx: frame.sourceWidth / frame.width, sy: frame.sourceHeight / frame.height });
      } catch (e) {
        jlog(opts, { event: 'warn', msg: 'debug_write_failed: ' + e.message });
      }
    }

      jlog(opts, { event: 'frame', t_ms: frame.tMs, faces: faces.length,
                   chosen: !!pick.face, faceId: pick.faceId, scores: pick.scores,
                   elapsed_ms: elapsed });
    }
  } catch (e) {
    extractorOk = false;
    extractorErr = e.message;
    jlog(opts, { event: 'extractor_error', error: e.message });
  }

  if (framesProcessed === 0) {
    return {
      samples: null,
      reason: extractorErr ? 'extractor_error: ' + extractorErr : 'no_frames_extracted',
      speakerMap,
      detectorProvider,
      detectorProviderFallbackReason,
      landmarkerProvider,
      landmarkerProviderFallbackReason,
    };
  }
  if (framesWithFace / framesProcessed < 0.5) {
    return {
      samples: null,
      reason: 'low_face_yield: ' + framesWithFace + '/' + framesProcessed,
      framesProcessed,
      framesWithFace,
      framesSlow,
      speakerMap,
      detectorProvider,
      detectorProviderFallbackReason,
      landmarkerProvider,
      landmarkerProviderFallbackReason,
    };
  }
  if (!extractorOk) {
    jlog(opts, { event: 'partial_extraction', framesProcessed });
    // Continue with what we have — partial is better than nothing.
  }

  const cxs = kalman1d(raw.map((r) => r.cx));
  const cys = kalman1d(raw.map((r) => r.cy));
  const scaleHFit = srcH / targetH;
  let samples = raw.map((r, i) => ({
    t_ms: r.t_ms,
    cx: Math.round(cxs[i]),
    cy: Math.round(cys[i]),
    scale: +scaleHFit.toFixed(3),
    letterbox: false,
  }));
  samples = clampVelocity(samples, opts.maxPanPxS);

  // Compute diagnostic aggregates for the success-path test.
  const mouthYStddev = stddev(mouthYs);
  const landmarkDetector = isLandmarkerReady() ? 'onnx@pfld-68' : null;

  return {
    samples, framesProcessed, framesWithFace, framesSlow, speakerMap, extractorOk,
    landmarkDetector,
    trackerFlips,
    samplesWithKeypoints,
    totalLandmarksPerFace,
    mouthYStddev,
    detectorProvider,
    detectorProviderFallbackReason,
    landmarkerProvider,
    landmarkerProviderFallbackReason,
  };
}

function stddev(arr) {
  if (!arr || arr.length < 2) return 0;
  const mean = arr.reduce((a, b) => a + b, 0) / arr.length;
  const variance = arr.reduce((a, b) => a + (b - mean) ** 2, 0) / arr.length;
  return Math.sqrt(variance);
}

(async () => {
  const opts = parseArgs(process.argv.slice(2));

  // Output default
  if (!opts.out) opts.out = './crop_path.json';

  if (!opts.in) die('source required — pass positional or --in <path>; see --help');
  if (!existsSync(opts.in)) die('source not found: ' + opts.in);

  const dims = probe(opts.in);
  if (!dims || !dims.width || !dims.height) die('could not probe ' + opts.in);
  const { width: srcW, height: srcH, duration_ms } = dims;

  if (opts.startMs == null) opts.startMs = 0;
  if (opts.endMs == null) opts.endMs = duration_ms || (opts.startMs + 5000);
  if (opts.endMs <= opts.startMs) die('end-ms must be greater than start-ms');

  const aspect = parseAspect(opts.targetAspect);
  const targetH = TARGET_H_DEFAULT;
  const targetW = Math.round((targetH * aspect.w) / aspect.h);

  let samples = null;
  let fallback = false;
  let reason = null;
  let detectorLabel = 'onnxruntime@ultraface-rfb-320';
  let stats = null;
  let resolvedMap = null;
  let landmarkDetectorLabel = null;
  let detectorProvider = null;
  let detectorProviderFallbackReason = null;
  let landmarkerProvider = null;
  let landmarkerProviderFallbackReason = null;

  if (opts.mode === 'face') {
    try {
      const r = await detectPath(opts, srcW, srcH, targetW, targetH);
      samples = r.samples;
      reason = r.reason || null;
      landmarkDetectorLabel = r.landmarkDetector || null;
      detectorProvider = r.detectorProvider || null;
      detectorProviderFallbackReason = r.detectorProviderFallbackReason || null;
      landmarkerProvider = r.landmarkerProvider || null;
      landmarkerProviderFallbackReason = r.landmarkerProviderFallbackReason || null;
      if (r.samples) {
        stats = {
          framesProcessed: r.framesProcessed,
          framesWithFace: r.framesWithFace,
          framesSlow: r.framesSlow || 0,
          extractorOk: r.extractorOk !== false,
          trackerFlips: r.trackerFlips || 0,
          samplesWithKeypoints: r.samplesWithKeypoints || 0,
          totalLandmarksPerFace: r.totalLandmarksPerFace || 0,
          mouthYStddev: +(r.mouthYStddev || 0).toFixed(3),
        };
      } else if (r.framesProcessed) {
        stats = {
          framesProcessed: r.framesProcessed,
          framesWithFace: r.framesWithFace || 0,
          framesSlow: r.framesSlow || 0,
        };
      }
      resolvedMap = r.speakerMap || null;
    } catch (e) {
      reason = 'detect_threw: ' + e.message;
    } finally {
      closeDetector();
      closeLandmarker();
    }
  } else {
    reason = 'mode=' + opts.mode + ' (face detection skipped)';
  }

  if (!samples) {
    fallback = true;
    const cc = fallbackSamples(opts, srcW, srcH, targetW, targetH, reason);
    samples = cc.samples;
    detectorLabel = opts.fallbackMode + '-fallback';
  }

  const result = {
    version: 2,
    clip_id: null,
    source_w: srcW,
    source_h: srcH,
    target_w: targetW,
    target_h: targetH,
    mode: fallback ? opts.fallbackMode : opts.mode,
    detector: detectorLabel,
    landmark_detector: landmarkDetectorLabel,
    detector_provider: detectorProvider || undefined,
    detector_provider_fallback_reason: detectorProviderFallbackReason || undefined,
    landmark_provider: landmarkerProvider || undefined,
    landmark_provider_fallback_reason: landmarkerProviderFallbackReason || undefined,
    samples,
    interp: 'linear',
    fallback_used: fallback,
    fallback_reason: reason,
    stats: stats || undefined,
    speaker_map: resolvedMap || undefined,
  };

  mkdirSync(dirname(resolvePath(opts.out)), { recursive: true });
  writeFileSync(opts.out, JSON.stringify(result, null, 2));
  process.stdout.write(JSON.stringify({
    event: 'done', samples: samples.length, fallback, detector: detectorLabel,
    framesProcessed: stats ? stats.framesProcessed : 0,
    framesWithFace: stats ? stats.framesWithFace : 0,
    output: opts.out,
  }) + '\n');
})();
