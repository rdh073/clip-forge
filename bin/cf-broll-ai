#!/usr/bin/env node
// cf-broll-ai — dispatcher for /clip-forge:broll-ai (v0.4.0 pillar 5).
//
// Reads existing ./clips/<slug>/<clip-id>/broll.json (from /clip-forge:broll
// Pexels-first run), identifies gaps (sentences with no Pexels match or
// score < 0.5), and generates AI images for each via the resolved visual
// provider. Updates broll.json additively with AI-source entries.
//
// ALSO supports stylize mode: --stylize-segment <id> --preset <name>. In
// stylize mode the dispatcher operates on a SINGLE segment by id; the
// preset name maps to a pre-canned prompt (no creator visual style this
// round).
//
// HARD INVARIANT (moat anchor):
//   AI never touches is_primary segments. Three-layer enforcement:
//     1. broll.json segment carries is_primary; refuse if true.
//     2. crop_path.json stats auto-detect — refuse if yield > 0.5.
//     3. Renderer refuses to mux AI assets onto is_primary slots.
//   Defense in depth; one bypass is one bug.
//
// Flags:
//   --slug <slug>              REQUIRED
//   --clip-id <id>             REQUIRED
//   --stylize-segment <id>     stylize mode — operate on this segment only
//   --preset <name>            cinematic|comic|anime (stylize mode only)
//   --max-cutaways <N>         cap on AI gap-fills (default 4)
//   --aspect <9:16|1:1|16:9>   target canvas aspect (default 9:16)
//   --yolo                     silent skip at 100% budget
//   --no-json-logs             suppress NDJSON event lines
//
// Mock injection: CF_VISUAL_MOCK=<path> bypasses the network adapter.

import { spawnSync } from 'node:child_process';
import {
  existsSync, readFileSync, writeFileSync, mkdirSync,
  renameSync, openSync, fsyncSync, closeSync,
} from 'node:fs';
import { dirname, join, resolve as resolvePath, basename } from 'node:path';

import { generate as visualGenerate, resolveProvider as resolveVisualProvider } from './lib/visual.mjs';
import {
  loadManifest, saveManifest, projectCharge, recordCharge, recordSkip,
  raiseCap, DEFAULT_BUDGET_USD,
} from './lib/budget.mjs';
import { loadCropStats, gateAiOnSegment } from './lib/primary-detect.mjs';

const STYLE_PRESETS = {
  cinematic: 'cinematic film still, dramatic lighting, anamorphic lens, shallow depth of field, color graded',
  comic:     'comic book panel, bold ink outlines, halftone shading, vibrant flat colors',
  anime:     'anime key visual, cel shaded, soft rim light, expressive composition',
};

function die(msg, code = 1) {
  process.stderr.write('cf-broll-ai: ' + msg + '\n');
  process.exit(code);
}

function parseArgs(argv) {
  const out = {
    slug: null, clipId: null,
    stylizeSegment: null, preset: null,
    maxCutaways: 4, aspect: '9:16',
    yolo: false, jsonLogs: true,
    brollJsonPath: null, cropPathFile: null,
    manifestPath: null,
  };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--help' || a === '-h') { printHelp(); process.exit(0); }
    else if (a === '--slug')             out.slug = argv[++i];
    else if (a === '--clip-id')          out.clipId = argv[++i];
    else if (a === '--stylize-segment')  out.stylizeSegment = argv[++i];
    else if (a === '--preset')           out.preset = argv[++i];
    else if (a === '--max-cutaways')     out.maxCutaways = parseInt(argv[++i] || '4', 10);
    else if (a === '--aspect')           out.aspect = argv[++i];
    else if (a === '--yolo')             out.yolo = true;
    else if (a === '--no-json-logs')     out.jsonLogs = false;
    else if (a === '--broll-json')       out.brollJsonPath = argv[++i];
    else if (a === '--crop-path')        out.cropPathFile = argv[++i];
    else if (a === '--manifest')         out.manifestPath = argv[++i];
    else die('unknown flag: ' + a);
  }
  if (!out.slug)   die('--slug required');
  if (!out.clipId) die('--clip-id required');
  return out;
}

function printHelp() {
  process.stdout.write(`cf-broll-ai — fill broll.json gaps with AI imagery, or stylize a segment

usage:
  cf-broll-ai --slug <slug> --clip-id <id> [--max-cutaways N] [--aspect 9:16|1:1|16:9]
  cf-broll-ai --slug <slug> --clip-id <id> --stylize-segment <id> --preset cinematic|comic|anime

env:
  FAL_API_KEY                fal.ai Flux Schnell (default, ~$0.003/img)
  GEMINI_API_KEY             Nano Banana (~$0.04/img)
  REPLICATE_API_TOKEN        Replicate fallback
  CF_VISUAL_PROVIDER         force fal|nanobanana|replicate
  CF_VISUAL_MOCK=<path>      inject deterministic mock (test path)
  CF_AI_BUDGET_USD           cumulative paid-skill cost cap (default ${DEFAULT_BUDGET_USD})
`);
}

function jlog(opts, obj) {
  if (opts.jsonLogs) process.stdout.write(JSON.stringify(obj) + '\n');
}

function readJsonSafe(path) {
  if (!existsSync(path)) return null;
  try { return JSON.parse(readFileSync(path, 'utf-8')); } catch { return null; }
}

function writeJsonAtomicSync(path, obj) {
  mkdirSync(dirname(path), { recursive: true });
  const tmp = path + '.tmp.' + process.pid + '.' + Date.now();
  writeFileSync(tmp, JSON.stringify(obj, null, 2) + '\n');
  const fd = openSync(tmp, 'r+');
  try { fsyncSync(fd); } finally { closeSync(fd); }
  renameSync(tmp, path);
  return path;
}

function isGapSegment(segment) {
  if (!segment || typeof segment !== 'object') return false;
  if (segment.is_primary === true) return false;
  if (segment.source === 'ai_generated' || segment.source === 'ai_stylized') return false;
  if (segment.source === 'pexels' && typeof segment.score === 'number' && segment.score >= 0.5) return false;
  if (segment.source === 'ai_gap_pending') return true;
  if (segment.source === 'pexels' && segment.score != null && segment.score < 0.5) return true;
  if (!segment.path && !segment.source) return true;
  return false;
}

function buildPromptFromSentence(sentence, brandKit) {
  const text = String(sentence || '').slice(0, 200);
  const keywords = text
    .replace(/[^\w\s'-]/g, ' ')
    .split(/\s+/)
    .filter((w) => w.length >= 4)
    .slice(0, 6)
    .join(' ');
  const base = keywords || text || 'abstract background';
  if (brandKit && brandKit.colors) {
    return base + ' cinematic photograph, brand palette';
  }
  return base + ' cinematic photograph';
}

(async () => {
  const opts = parseArgs(process.argv.slice(2));

  // Locate broll.json.
  const brollPath = opts.brollJsonPath || join('./clips', opts.slug, opts.clipId, 'broll.json');
  const broll = readJsonSafe(brollPath) || { version: 1, clip_id: opts.clipId, segments: [], cutaways: [] };
  if (!Array.isArray(broll.segments)) broll.segments = [];
  if (!Array.isArray(broll.cutaways)) broll.cutaways = [];

  // Locate crop_path.json for primary-face auto-detect.
  const cropPath = opts.cropPathFile || join('./clips', opts.slug, opts.clipId, 'crop_path.json');
  const cropStats = loadCropStats(cropPath);

  // Pre-flight: visual provider.
  const providerInfo = resolveVisualProvider();
  const usingMock = !!process.env.CF_VISUAL_MOCK;
  if (!providerInfo && !usingMock) {
    jlog(opts, { event: 'done', ok: true, fallback_used: true,
                 fallback_reason: 'no_visual_provider',
                 message: 'set FAL_API_KEY or GEMINI_API_KEY or REPLICATE_API_TOKEN to enable AI b-roll' });
    process.exit(0);
  }

  // Budget manifest.
  const manifestPath = opts.manifestPath || join('./renders', opts.slug, 'render_manifest.json');
  let manifest = loadManifest(manifestPath, { slug: opts.slug });

  const outputDir = join('./clips', opts.slug, opts.clipId, 'broll-ai');
  mkdirSync(outputDir, { recursive: true });

  // ----- STYLIZE MODE -----
  if (opts.stylizeSegment) {
    const seg = broll.segments.find((s) => String(s.id || s.sentence_idx) === String(opts.stylizeSegment));
    if (!seg) {
      jlog(opts, { event: 'done', ok: false, fallback_used: true,
                   fallback_reason: 'stylize_segment_not_found',
                   detail: 'segment id=' + opts.stylizeSegment });
      process.exit(0);
    }
    const gate = gateAiOnSegment({ segment: seg, cropStats });
    if (!gate.allowed) {
      jlog(opts, { event: 'refused', segment_id: opts.stylizeSegment,
                   refusal_reason: gate.refusal_reason, detail: gate.detail });
      jlog(opts, { event: 'done', ok: true, refused: 1, generated: 0,
                   refusal_reason: gate.refusal_reason });
      process.exit(0);
    }
    const preset = STYLE_PRESETS[opts.preset || 'cinematic'] || STYLE_PRESETS.cinematic;
    const targetPath = join(outputDir, 'stylize-' + opts.stylizeSegment + '.png');
    const estCost = 0.04;
    const proj = projectCharge(manifest, estCost);
    if (!proj.allowed) {
      jlog(opts, { event: 'budget_exhausted', cumulative_usd: manifest.ai_costs.cumulative_usd,
                   cap_usd: manifest.ai_costs.budget_cap_usd });
      jlog(opts, { event: 'done', ok: true, generated: 0, budget_exhausted: true });
      process.exit(0);
    }
    if (proj.checkpoint_hit && !opts.yolo) {
      jlog(opts, { event: 'budget_checkpoint', used_pct: proj.used_pct_after,
                   cap_usd: manifest.ai_costs.budget_cap_usd });
    }
    const r = await visualGenerate({
      prompt:  preset + '; ' + (seg.sentence || ''),
      paths:   [targetPath],
      aspect:  opts.aspect,
      count:   1,
      seed:    42,
    });
    if (r.fallback_used) {
      jlog(opts, { event: 'visual_fallback', fallback_reason: r.fallback_reason });
      jlog(opts, { event: 'done', ok: true, fallback_used: true,
                   fallback_reason: r.fallback_reason });
      process.exit(0);
    }
    recordCharge(manifest, {
      provider: r.provider_used, kind: 'visual', delta_usd: r.cost_usd || estCost,
      clip_id:  opts.clipId,
    });
    saveManifest(manifestPath, manifest);
    seg.source       = 'ai_stylized';
    seg.provider     = r.provider_used;
    seg.prompt       = r.prompt_used;
    seg.cost_usd     = r.cost_usd || estCost;
    seg.path         = r.paths[0];
    seg.is_primary   = false;
    writeJsonAtomicSync(brollPath, broll);
    jlog(opts, { event: 'done', ok: true, generated: 1, stylized: true,
                 segment_id: opts.stylizeSegment, provider_used: r.provider_used,
                 cost_usd: r.cost_usd || estCost });
    process.exit(0);
  }

  // ----- GAP-FILL MODE -----
  const candidates = broll.segments.filter(isGapSegment).slice(0, opts.maxCutaways);
  let generated = 0;
  let refused = 0;
  const refusals = [];
  let budgetExhausted = false;
  const brandKit = broll.brand_kit || null;

  for (const seg of candidates) {
    const gate = gateAiOnSegment({ segment: seg, cropStats });
    if (!gate.allowed) {
      refused++;
      refusals.push({ segment_id: seg.id || seg.sentence_idx,
                      refusal_reason: gate.refusal_reason, detail: gate.detail });
      jlog(opts, { event: 'refused', segment_id: seg.id || seg.sentence_idx,
                   refusal_reason: gate.refusal_reason, detail: gate.detail });
      seg.refused = true;
      seg.refusal_reason = gate.refusal_reason;
      continue;
    }
    const estCost = providerInfo && providerInfo.adapter.estimateCostUsd
      ? providerInfo.adapter.estimateCostUsd(1)
      : 0.04;
    const proj = projectCharge(manifest, estCost);
    if (!proj.allowed) {
      budgetExhausted = true;
      recordSkip(manifest, { clip_id: opts.clipId, reason: 'budget_exhausted' });
      if (opts.yolo) continue;
      jlog(opts, { event: 'budget_exhausted', cumulative_usd: manifest.ai_costs.cumulative_usd,
                   cap_usd: manifest.ai_costs.budget_cap_usd });
      continue;
    }
    if (proj.checkpoint_hit && !opts.yolo) {
      jlog(opts, { event: 'budget_checkpoint', used_pct: proj.used_pct_after,
                   cap_usd: manifest.ai_costs.budget_cap_usd });
    }
    const segId = String(seg.id || seg.sentence_idx || 'seg-' + generated);
    const targetPath = join(outputDir, 'gap-' + segId + '.png');
    const prompt = buildPromptFromSentence(seg.sentence || seg.query || '', brandKit);
    const r = await visualGenerate({
      prompt, paths: [targetPath], aspect: opts.aspect, count: 1, seed: 42,
      brand_kit: brandKit,
    });
    if (r.fallback_used) {
      jlog(opts, { event: 'visual_fallback', segment_id: segId, fallback_reason: r.fallback_reason });
      seg.source = 'ai_gap_failed';
      seg.fallback_reason = r.fallback_reason;
      continue;
    }
    recordCharge(manifest, {
      provider: r.provider_used, kind: 'visual', delta_usd: r.cost_usd || estCost,
      clip_id:  opts.clipId,
    });
    seg.source     = 'ai_generated';
    seg.provider   = r.provider_used;
    seg.prompt     = r.prompt_used;
    seg.cost_usd   = r.cost_usd || estCost;
    seg.path       = r.paths[0];
    seg.is_primary = false;
    if (typeof seg.end_ms === 'number' && typeof seg.start_ms === 'number') {
      const dur = seg.end_ms - seg.start_ms;
      if (dur > 3000) {
        seg.duration_ms = 3000;
        seg.duration_capped = true;
      }
    }
    generated++;
  }
  saveManifest(manifestPath, manifest);
  writeJsonAtomicSync(brollPath, broll);

  jlog(opts, {
    event: 'done', ok: true,
    generated, refused, refusals,
    budget_exhausted: budgetExhausted,
    cumulative_usd:   manifest.ai_costs.cumulative_usd,
    cap_usd:          manifest.ai_costs.budget_cap_usd,
    provider_used:    providerInfo ? providerInfo.name : 'mock',
  });
})().catch((e) => {
  process.stdout.write(JSON.stringify({ event: 'done', ok: false,
                                         fallback_used: true,
                                         fallback_reason: 'uncaught: ' + e.message }) + '\n');
  process.exit(0);
});
