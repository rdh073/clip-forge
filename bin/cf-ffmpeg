#!/usr/bin/env node
// cf-ffmpeg — small CLI wrapping ffmpeg with the presets ClipForge needs.
// Subcommands:
//   probe              <file>                               → JSON {duration_s,width,height,fps}
//   ingest             <src> <dst>                          → re-mux/transcode to .mp4
//   render             --manifest <edit.json>               → full clip render (uses animated crop)
//   reframe-animated   --crop-path <p> --source <s> --output <o> [--start-ms N --end-ms N]
//                                                           → crop+scale only, animated by samples[]
//   caption-burn       <src> <ass> <dst>                    → burn .ass subs
//   music-mix          <src> <track> <dst> [--duck]         → sidechain ducking mix
//   watermark          <src> <logo> <dst>                   → bottom-right watermark
//
// All ffmpeg invocations route through `runFfmpeg` so progress streaming and
// error tailing live in one place. The animated-crop path uses the Phase 2D
// expression builder (bin/lib/crop-expression-builder.mjs) — see
// docs/bench-v0.2.0.md for why we don't use ffmpeg sendcmd here.

import { spawn, spawnSync } from 'node:child_process';
import { readFileSync, existsSync, mkdirSync, writeFileSync, unlinkSync, statSync, renameSync } from 'node:fs';
import { dirname, resolve as resolvePath, join, basename } from 'node:path';
import { tmpdir, homedir } from 'node:os';

import { chooseRenderMode, buildFilterScript } from './lib/crop-expression-builder.mjs';
import { buildFfmpegPlan } from './lib/ffmpeg-encoder.mjs';
import { assertPlanInvariants, buildSpliceGraph, JUNCTION_XFADE_S } from './lib/tighten-splice.mjs';
import { computeJunctionMetrics } from './lib/junction-analyzer.mjs';
import { buildRenderReport, writeRenderReport } from './lib/render-report.mjs';
import {
  chooseAspectCanvas,
  buildHookOverlayAss,
  buildProgressBarDrawbox,
} from './lib/overlay-builder.mjs';
import { buildVtt, buildSrt } from './lib/srt-vtt.mjs';
import { synthesize as ttsSynthesize } from './lib/tts.mjs';
import { loadManifest, snapshotForReport } from './lib/budget.mjs';
import { resolveKitForEdit } from './lib/brand-kit.mjs';
import { composeBrandKitFilter } from './lib/brand-overlay-builder.mjs';

const GRAPH_SIZE_WARN_BYTES = 8192;

function die(msg, code = 1) {
  process.stderr.write('cf-ffmpeg: ' + msg + '\n');
  process.exit(code);
}

function which(bin) {
  const r = spawnSync('sh', ['-c', 'command -v ' + bin]);
  return r.status === 0 ? r.stdout.toString().trim() : null;
}

if (!which('ffmpeg')) die('ffmpeg not found in PATH');
if (!which('ffprobe')) die('ffprobe not found in PATH');

// One-shot probe for librsvg support in the local ffmpeg build. SVG brand
// assets need librsvg compiled in; if absent, the brand-kit overlay path
// skips SVG inputs with a `librsvg_not_available` warning rather than
// crashing mid-render. Cached after first call so we pay the cost once.
let _librsvgAvailable = null;
function probeLibrsvg() {
  // Test-time override always wins so the SVG-degrade integration test can
  // simulate a librsvg-less ffmpeg build without rebuilding ffmpeg.
  if (process.env.CF_FORCE_NO_LIBRSVG === '1') return false;
  if (_librsvgAvailable !== null) return _librsvgAvailable;
  const r = spawnSync('ffmpeg', ['-hide_banner', '-loglevel', 'error', '-buildconf'], { encoding: 'utf-8' });
  // Most distro builds expose "--enable-librsvg" in the build config.
  // Fallback: search demuxer list for "svg".
  if (r.status === 0 && /--enable-librsvg/.test(r.stdout || '')) {
    _librsvgAvailable = true;
  } else {
    const r2 = spawnSync('ffmpeg', ['-hide_banner', '-loglevel', 'error', '-demuxers'], { encoding: 'utf-8' });
    _librsvgAvailable = r2.status === 0 && /svg_pipe|libsvg/i.test(r2.stdout || '');
  }
  return _librsvgAvailable;
}

function runFfmpeg(args, { onProgress } = {}) {
  return new Promise((res, rej) => {
    const p = spawn('ffmpeg', ['-hide_banner', '-y', '-loglevel', 'error', '-progress', 'pipe:2', ...args]);
    const stderrTail = [];
    p.stderr.on('data', (chunk) => {
      const lines = chunk.toString().split('\n');
      for (const line of lines) {
        if (!line) continue;
        if (line.startsWith('out_time_ms=') && onProgress) {
          const ms = parseInt(line.slice('out_time_ms='.length), 10);
          if (!Number.isNaN(ms)) onProgress({ out_ms: Math.floor(ms / 1000) });
        }
        stderrTail.push(line);
        if (stderrTail.length > 60) stderrTail.shift();
      }
    });
    p.on('error', rej);
    p.on('close', (code) => {
      if (code === 0) res();
      else rej(new Error('ffmpeg exit ' + code + '\n' + stderrTail.slice(-30).join('\n')));
    });
  });
}

async function runFfmpegPlan(plan, opts = {}) {
  const t0 = Date.now();
  try {
    await runFfmpeg(plan.args, opts);
  } catch (e) {
    if (!plan.fallbackArgs) throw e;
    process.stdout.write(JSON.stringify({
      event: 'encoder_fallback',
      from: plan.encoder,
      to: plan.fallbackEncoder,
      reason: firstLine(e.message),
    }) + '\n');
    await runFfmpeg(plan.fallbackArgs, opts);
  }
  // T3: wall_ms = ffmpeg spawn() → exit, exclusive of pre/post I/O.
  plan.wallMs = Date.now() - t0;
}

// Extract a stream's PCM (mono int16 LE 48 kHz) to a temp file. Returns the
// path. Caller cleans up. Used to decode rendered output's audio for
// junction analysis, and to decode source audio (post-seek) for the
// no-xfade synthesis windows.
function extractMonoPcm({ source, output, startMs, endMs }) {
  const args = ['-y', '-hide_banner', '-loglevel', 'error'];
  if (typeof startMs === 'number') args.push('-ss', (startMs / 1000).toFixed(3));
  if (typeof endMs   === 'number') args.push('-to', (endMs   / 1000).toFixed(3));
  args.push('-i', source, '-vn', '-ac', '1', '-ar', '48000', '-f', 's16le', '-c:a', 'pcm_s16le', output);
  const r = spawnSync('ffmpeg', args);
  if (r.status !== 0) {
    throw new Error('extractMonoPcm: ' + (r.stderr ? r.stderr.toString().split('\n').slice(-3).join(' ') : 'exit ' + r.status));
  }
}

function readPcm(path) {
  const buf = readFileSync(path);
  return new Int16Array(buf.buffer, buf.byteOffset, Math.floor(buf.byteLength / 2));
}

function firstLine(msg) {
  return String(msg || '').split('\n').find(Boolean) || 'ffmpeg failed';
}

function probeStreams(file) {
  const r = spawnSync('ffprobe', [
    '-v', 'error', '-print_format', 'json',
    '-show_streams', '-show_format', file,
  ]);
  if (r.status !== 0) return { ok: false, stderr: r.stderr.toString(), data: null };
  try { return { ok: true, data: JSON.parse(r.stdout.toString()) }; }
  catch (e) { return { ok: false, stderr: e.message, data: null }; }
}

function hasAudioStream(file) {
  const p = probeStreams(file);
  if (!p.ok) return false;
  return (p.data.streams || []).some((s) => s.codec_type === 'audio');
}

async function probe(file) {
  const r = probeStreams(file);
  if (!r.ok) die('ffprobe failed: ' + r.stderr);
  const data = r.data;
  const v = (data.streams || []).find((s) => s.codec_type === 'video') || {};
  const fmt = data.format || {};
  let fps = 0;
  if (v.r_frame_rate && v.r_frame_rate.includes('/')) {
    const [n, d] = v.r_frame_rate.split('/').map(Number);
    fps = d ? +(n / d).toFixed(3) : 0;
  }
  process.stdout.write(JSON.stringify({
    duration_s: +parseFloat(fmt.duration || 0).toFixed(3),
    width: v.width || 0,
    height: v.height || 0,
    fps,
    container: fmt.format_name,
    video_codec: v.codec_name,
  }) + '\n');
}

async function ingest(src, dst) {
  mkdirSync(dirname(dst), { recursive: true });
  const plan = buildFfmpegPlan(['-i', src], ['-c:a', 'aac', '-b:a', '192k', dst], {
    cpuPreset: 'fast',
    cpuCrf: 18,
  });
  await runFfmpegPlan(plan);
  process.stdout.write(JSON.stringify({ event: 'done', path: dst }) + '\n');
}

async function captionBurn(src, ass, dst) {
  mkdirSync(dirname(dst), { recursive: true });
  // ass filter needs escaped path
  const ascii = ass.replace(/\\/g, '\\\\').replace(/:/g, '\\:').replace(/'/g, "\\'");
  const plan = buildFfmpegPlan(['-i', src, '-vf', "ass='" + ascii + "'"], ['-c:a', 'copy', dst], {
    cpuPreset: 'fast',
    cpuCrf: 20,
  });
  await runFfmpegPlan(plan);
  process.stdout.write(JSON.stringify({ event: 'done', path: dst }) + '\n');
}

async function musicMix(src, track, dst, duck) {
  mkdirSync(dirname(dst), { recursive: true });
  const filter = duck
    ? '[1:a]volume=0.18[m];[m][0:a]sidechaincompress=threshold=-28dB:ratio=6:attack=5:release=250[ducked];[0:a][ducked]amix=inputs=2:duration=first[a]'
    : '[1:a]volume=0.18[m];[0:a][m]amix=inputs=2:duration=first[a]';
  await runFfmpeg([
    '-i', src, '-i', track,
    '-filter_complex', filter,
    '-map', '0:v', '-map', '[a]',
    '-c:v', 'copy', '-c:a', 'aac', '-b:a', '192k',
    '-shortest', dst,
  ]);
  process.stdout.write(JSON.stringify({ event: 'done', path: dst }) + '\n');
}

async function watermark(src, logo, dst) {
  mkdirSync(dirname(dst), { recursive: true });
  // bottom-right with 8% padding, 70% opacity
  const filter = '[1:v]format=rgba,colorchannelmixer=aa=0.7[wm];[0:v][wm]overlay=W-w-W*0.04:H-h-H*0.04';
  const plan = buildFfmpegPlan(['-i', src, '-i', logo, '-filter_complex', filter], ['-c:a', 'copy', dst], {
    cpuPreset: 'fast',
    cpuCrf: 20,
  });
  await runFfmpegPlan(plan);
  process.stdout.write(JSON.stringify({ event: 'done', path: dst }) + '\n');
}

// Build ffmpeg argv for a crop+scale render driven by crop_path.json.
//
// Returns { args, scriptFile } — scriptFile is the temp filter-script path
// when in 'filter-script' mode (caller must clean up), otherwise null.
//
// Exported (via the test helper below) so unit tests can assert argv shape
// without invoking ffmpeg.
export function planCropArgs({ crop, source, output, startMs, endMs, captionsPath, quality, audioSource, overlayFilter, deterministic, brandKitChain, brandKitFinalLabel, brandKitExtraInputs }) {
  const decision = chooseRenderMode(crop);

  const args = [];
  if (typeof startMs === 'number') args.push('-ss', (startMs / 1000).toFixed(3));
  if (typeof endMs   === 'number') args.push('-to', (endMs   / 1000).toFixed(3));
  args.push('-i', source);
  if (audioSource) args.push('-i', audioSource);
  // Brand-kit asset inputs (logo, lower-third PNG) come after source +
  // audio. The brand-kit chain's input indices were assigned with this
  // ordering in mind (see resolveBrandKitForRender below).
  if (Array.isArray(brandKitExtraInputs)) {
    for (const p of brandKitExtraInputs) args.push('-i', p);
  }
  // Brand-kit overlays require multi-input filter_complex — force script
  // mode when the chain is present, otherwise the inline -vf path
  // can't reference the extra inputs.
  const useFilterScript = decision.mode === 'filter-script' || !!brandKitChain;

  let scriptFile = null;
  if (useFilterScript) {
    scriptFile = join(tmpdir(), 'clip-forge-render-' + process.pid + '-' + Date.now() + '.fc');
    const overlayTail = overlayFilter ? ',' + overlayFilter : '';
    const captionTail = captionsPath ? appendCaptionsToScript(captionsPath) : '';
    let body = buildFilterScript(crop);
    if (brandKitChain && brandKitFinalLabel) {
      // Splice the brand-kit chain between crop+scale and the overlay/
      // caption tail. The crop script ends in `[v]\n`; rewrite to:
      //   [0:v]<crop>,<scale>[vcrop];
      //   <brandkit chain reading [vcrop] → [<final>]>;
      //   [<final>]<inner tail or null>[v]
      //
      // The inner tail is overlay (drawbox) THEN captions (ass). When both
      // are empty we still need a single filter on the chain — use `null`.
      const innerTail =
        (overlayTail ? overlayTail.slice(1) : '') +              // drop leading comma
        (captionTail
          ? (overlayTail ? captionTail : captionTail.slice(1))  // keep/drop leading comma
          : '');
      const tailFilter = innerTail || 'null';
      body = body.replace('[v]\n',
        '[vcrop];' + brandKitChain + ';[' + brandKitFinalLabel + ']' + tailFilter + '[v]\n');
    } else {
      body = body.replace('[v]\n', overlayTail + captionTail + '[v]\n');
    }
    writeFileSync(scriptFile, body);
    args.push('-filter_complex_script', scriptFile);
    args.push('-map', '[v]', '-map', audioSource ? '1:a?' : '0:a?');
  } else {
    // Inline -vf path. Append progress-bar drawbox THEN captions burn so
    // ASS dialogue renders on top of the bar.
    let vf = decision.filterArg;
    if (overlayFilter) vf += ',' + overlayFilter;
    if (captionsPath && existsSync(captionsPath)) {
      const ascii = captionsPath.replace(/\\/g, '\\\\').replace(/:/g, '\\:').replace(/'/g, "\\'");
      vf += ",ass='" + ascii + "'";
    }
    args.push('-vf', vf);
    if (audioSource) args.push('-map', '0:v', '-map', '1:a?');
  }

  const tailArgs = ['-c:a', 'aac', '-b:a', '192k', '-movflags', '+faststart'];
  if (deterministic) {
    tailArgs.push('-fflags', '+bitexact', '-tune', 'zerolatency',
                  '-x264-params', 'sliced-threads=0:threads=1');
  }
  tailArgs.push(output);
  const plan = buildFfmpegPlan(args, tailArgs, {
    cpuPreset: deterministic ? 'medium' : (quality === 'fast' ? 'fast' : 'slow'),
    cpuCrf: quality === 'fast' ? 22 : 18,
    encoder: deterministic ? 'cpu' : undefined,
  });

  return { args: plan.args, fallbackArgs: plan.fallbackArgs, encoder: plan.encoder,
           fallbackEncoder: plan.fallbackEncoder, scriptFile, mode: decision.mode, keyframeCount: decision.keyframeCount,
           byteSize: decision.byteSize };
}

function appendCaptionsToScript(captionsPath) {
  // Captions are inserted between the crop+scale chain output and [v]. The
  // filter-script body produced by buildFilterScript ends in '[v]\n'; we
  // splice an ass=… filter just before [v].
  const ascii = captionsPath.replace(/\\/g, '\\\\').replace(/:/g, '\\:').replace(/'/g, "\\'");
  return ",ass='" + ascii + "'";
}

// Insert a Hook style + Dialogue into an existing captions.ass body without
// mutating the on-disk original. Strategy:
//   - Splice the style line into [V4+ Styles] after the first existing
//     "Style: " line (the Default).
//   - Append the dialogue line(s) at the end of [Events].
// Falls back to building a standalone ASS body if the input is unrecognisable.
function insertHookIntoAss(originalAss, hookAssBlock) {
  // hookAssBlock = "Style: Hook,...\nDialogue: 5,...\n"
  const lines = hookAssBlock.split('\n');
  const styleLine    = lines.find((l) => l.startsWith('Style: ')) || '';
  const dialogueLine = lines.find((l) => l.startsWith('Dialogue: ')) || '';

  const body = originalAss;
  // Insert style after the first existing "Style: Default,..." line.
  const styleAnchor = body.indexOf('\nStyle: ');
  let withStyle;
  if (styleAnchor >= 0) {
    const afterFirstStyleEnd = body.indexOf('\n', styleAnchor + 1);
    if (afterFirstStyleEnd >= 0) {
      withStyle = body.slice(0, afterFirstStyleEnd + 1) + styleLine + '\n' + body.slice(afterFirstStyleEnd + 1);
    } else {
      withStyle = body + '\n' + styleLine + '\n';
    }
  } else {
    withStyle = body + '\n' + styleLine + '\n';
  }
  // Append dialogue at end (ensure trailing newline).
  const withDialogue = withStyle.endsWith('\n')
    ? withStyle + dialogueLine + '\n'
    : withStyle + '\n' + dialogueLine + '\n';
  return withDialogue;
}

function buildStandaloneHookAss(canvasW, canvasH, hookAssBlock) {
  return [
    '[Script Info]',
    'ScriptType: v4.00+',
    'PlayResX: ' + canvasW,
    'PlayResY: ' + canvasH,
    'Collisions: Normal',
    'WrapStyle: 0',
    'ScaledBorderAndShadow: yes',
    '',
    '[V4+ Styles]',
    'Format: Name, Fontname, Fontsize, PrimaryColour, SecondaryColour, OutlineColour, BackColour, Bold, Italic, Underline, StrikeOut, ScaleX, ScaleY, Spacing, Angle, BorderStyle, Outline, Shadow, Alignment, MarginL, MarginR, MarginV, Encoding',
    hookAssBlock.split('\n').find((l) => l.startsWith('Style: ')) || '',
    '',
    '[Events]',
    'Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text',
    hookAssBlock.split('\n').find((l) => l.startsWith('Dialogue: ')) || '',
    '',
  ].join('\n');
}

// Emit <output>.vtt + <output>.srt sidecars from captions.json. Best-effort:
// skipped silently if captions_json absent or empty. Returns
// {vtt: path|null, srt: path|null}.
function emitSidecars({ captionsJsonPath, captionsAssPath, outputPath }) {
  let sourcePath = null;
  if (captionsJsonPath && existsSync(captionsJsonPath)) {
    sourcePath = captionsJsonPath;
  } else if (captionsAssPath) {
    // Infer a sibling captions.json from the .ass path: captions.ass → captions.json.
    const candidate = captionsAssPath.replace(/\.ass$/i, '.json');
    if (candidate !== captionsAssPath && existsSync(candidate)) sourcePath = candidate;
  }
  if (!sourcePath) return { vtt: null, srt: null };

  let captions;
  try { captions = JSON.parse(readFileSync(sourcePath, 'utf-8')); }
  catch { return { vtt: null, srt: null }; }
  if (!captions || !Array.isArray(captions.lines) || captions.lines.length === 0) {
    return { vtt: null, srt: null };
  }
  const base = outputPath.replace(/\.[^./\\]+$/, '');
  const vttPath = base + '.vtt';
  const srtPath = base + '.srt';
  try {
    writeFileSync(vttPath, buildVtt(captions));
    writeFileSync(srtPath, buildSrt(captions));
    return { vtt: vttPath, srt: srtPath };
  } catch {
    return { vtt: null, srt: null };
  }
}

// Build ffmpeg passes for a combined splice + crop+scale render. Used when
// edit.json carries a `cuts` reference (tighten plan). For zero-cut plans
// or no plan, the caller falls back to planCropArgs (single-chain).
//
// Two-pass design (works around an ffmpeg combined-encode bug that drops
// trailing AAC frames when video EOFs slightly before audio):
//
//   Pass 1 (audio):  source.mp4 → audio splice graph → AAC mp4 temp
//   Pass 2 (video):  source.mp4 + audio temp → video splice graph + mux
//                    -c:v libx264 -c:a copy → final output
//
// If the source has no audio stream, only Pass 2 runs (with -map 0:a? to
// gracefully pass through "no audio").
//
// Returns `passes[]` for the renderer to execute sequentially, plus
// `tmpFiles[]` for cleanup on completion/failure.
export function planSpliceArgs({ crop, source, output, startMs, endMs, captionsPath, quality, tightenPlan, hasAudio, deterministic, audioSource, overlayFilter, brandKitChain, brandKitFinalLabel, brandKitExtraInputs }) {
  const cropDecision = chooseRenderMode(crop);
  const graph = buildSpliceGraph({
    plan: tightenPlan,
    cropFilterArg: cropDecision.filterArg,
    captionsPath,
    hasAudio,
    overlayFilter,
    brandKitChain,
    brandKitFinalLabel,
  });

  const seekArgs = [];
  if (typeof startMs === 'number') seekArgs.push('-ss', (startMs / 1000).toFixed(3));
  if (typeof endMs   === 'number') seekArgs.push('-to', (endMs   / 1000).toFixed(3));

  const passes = [];
  const tmpFiles = [];

  // ----- Pass 1: audio (only if source has audio) -----
  let audioTmpPath = null;
  if (hasAudio && graph.audioGraph) {
    audioTmpPath = join(tmpdir(), 'cf-tighten-audio-' + process.pid + '-' + Date.now() + '.m4a');
    tmpFiles.push(audioTmpPath);
    const audioArgs = [
      ...seekArgs, '-i', audioSource || source,
      '-filter_complex', graph.audioGraph,
      '-map', graph.mapAudio,
      '-c:a', 'aac', '-b:a', '192k',
      audioTmpPath,
    ];
    passes.push({
      label: 'audio',
      args: audioArgs,
      fallbackArgs: null,
      encoder: 'libx264', // unused for audio-only; carried for log uniformity
      fallbackEncoder: null,
      filterComplex: graph.audioGraph,
    });
  }

  // ----- Pass 2: video + mux (always runs) -----
  const videoArgs = [...seekArgs, '-i', source];
  if (audioTmpPath) videoArgs.push('-i', audioTmpPath);
  // Brand-kit asset inputs (logo / lower-third) come after source + audio.
  // Indices were assigned during composeBrandKitFilter() with the same
  // ordering rule (see resolveBrandKitForRender below).
  if (Array.isArray(brandKitExtraInputs)) {
    for (const p of brandKitExtraInputs) videoArgs.push('-i', p);
  }
  videoArgs.push('-filter_complex', graph.videoGraph);
  videoArgs.push('-map', graph.mapVideo);
  if (audioTmpPath) {
    videoArgs.push('-map', '1:a');
  } else if (hasAudio) {
    // Source has audio but we didn't pre-encode (shouldn't happen; defensive).
    videoArgs.push('-map', '0:a?');
  }
  // (No -map for audio when source has none — output is video-only.)

  const videoSuffix = [];
  if (audioTmpPath) {
    videoSuffix.push('-c:a', 'copy');
  } else if (hasAudio) {
    videoSuffix.push('-c:a', 'aac', '-b:a', '192k');
  }
  videoSuffix.push('-movflags', '+faststart');

  const encoderOverride = deterministic ? 'cpu' : undefined;
  if (deterministic) {
    videoSuffix.push('-fflags', '+bitexact', '-tune', 'zerolatency',
                    '-x264-params', 'sliced-threads=0:threads=1');
  }
  videoSuffix.push(output);

  const videoFfmpegPlan = buildFfmpegPlan(videoArgs, videoSuffix, {
    cpuPreset: deterministic ? 'medium' : (quality === 'fast' ? 'fast' : 'slow'),
    cpuCrf:    quality === 'fast' ? 22 : 18,
    encoder:   encoderOverride,
  });
  passes.push({
    label: 'video+mux',
    args: videoFfmpegPlan.args,
    fallbackArgs: videoFfmpegPlan.fallbackArgs,
    encoder: videoFfmpegPlan.encoder,
    fallbackEncoder: videoFfmpegPlan.fallbackEncoder,
    filterComplex: graph.videoGraph,
  });

  return {
    passes,
    tmpFiles,
    mode: 'splice',
    encoder: videoFfmpegPlan.encoder,
    keyframeCount: cropDecision.keyframeCount,
    byteSize: cropDecision.byteSize,
    // Largest graph (video usually > audio) — used for the ADD-3 size warning.
    filterComplex: graph.filterComplex,
    junctionCount: graph.junctionCount,
    keptCount: graph.keptCount,
    padDurS: graph.padDurS,
  };
}

// ----- v0.4.0 pillar 2: prepend / append audio (hook/outro TTS) -----
//
// Lazy-resolves a `{ tts: { text, voice_id, provider? } } | { audio_path }`
// spec to a WAV path on disk. TTS results are cached next to the output mp4
// so re-renders reuse them; the cache key is the TTS request shape (text +
// voice_id + provider).
//
// Returns { audio_path: string|null, fallback_used?, fallback_reason?,
//           cost_usd, provider_used, was_tts: boolean }
async function resolveStingerAudio(spec, { outputDir, kind }) {
  if (!spec || typeof spec !== 'object') return { audio_path: null };
  if (spec.audio_path) {
    if (existsSync(spec.audio_path)) return { audio_path: spec.audio_path };
    return { audio_path: null, fallback_used: true, fallback_reason: kind + '_audio_path_missing' };
  }
  if (!spec.tts || !spec.tts.text) return { audio_path: null };
  const cachePath = join(outputDir, basename(outputDir) + '.' + kind + '.wav');
  // Caching: if the WAV already exists and a sidecar manifest matches the
  // request, reuse. We keep this very thin — the cache file is named per
  // `kind`, and the sibling `.spec.json` carries the request hash.
  const sidecar = cachePath + '.spec.json';
  const reqShape = { text: spec.tts.text, voice_id: spec.tts.voice_id || null,
                      provider: spec.tts.provider || null };
  if (existsSync(cachePath) && existsSync(sidecar)) {
    try {
      const prev = JSON.parse(readFileSync(sidecar, 'utf-8'));
      if (prev && JSON.stringify(prev.req) === JSON.stringify(reqShape)) {
        return { audio_path: cachePath, was_tts: true, provider_used: prev.provider_used,
                 cost_usd: prev.cost_usd || 0, cached: true };
      }
    } catch { /* fall through to re-synth */ }
  }
  mkdirSync(outputDir, { recursive: true });
  const r = await ttsSynthesize({
    text:       spec.tts.text,
    voice_id:   spec.tts.voice_id,
    provider:   spec.tts.provider,
    audio_path: cachePath,
  });
  if (r.fallback_used) {
    return { audio_path: null, fallback_used: true,
              fallback_reason: r.fallback_reason, provider_used: r.provider_used };
  }
  try {
    writeFileSync(sidecar, JSON.stringify({
      req: reqShape, provider_used: r.provider_used, cost_usd: r.cost_usd,
      duration_ms: r.duration_ms,
    }, null, 2));
  } catch { /* sidecar is best-effort */ }
  return {
    audio_path:    r.audio_path,
    cost_usd:      r.cost_usd || 0,
    provider_used: r.provider_used,
    was_tts:       true,
  };
}

// Build an mp4 from a still frame + an audio wav. Used to materialise
// prepend/append stingers as concat-compatible mp4s before muxing.
async function buildStingerMp4({ audioPath, outputMp4, canvasW, canvasH }) {
  if (!audioPath || !existsSync(audioPath)) return false;
  const args = [
    '-hide_banner', '-loglevel', 'error', '-y',
    '-f', 'lavfi',
    '-i', 'color=c=black:s=' + canvasW + 'x' + canvasH + ':r=30',
    '-i', audioPath,
    '-shortest',
    '-c:v', 'libx264', '-pix_fmt', 'yuv420p', '-preset', 'fast', '-crf', '22',
    '-c:a', 'aac', '-b:a', '192k',
    '-movflags', '+faststart',
    outputMp4,
  ];
  const r = spawnSync('ffmpeg', args);
  return r.status === 0;
}

// Build an MP4 from a brand-kit endcard asset (PNG or MP4) sized to the
// render canvas dims. PNG endcards loop a still frame for `duration_ms`
// with a silent audio track so the concat-demuxer doesn't desync.
// MP4 endcards are transcoded to match the main render's canvas + codecs,
// trimmed/padded to `duration_ms` if specified.
async function buildEndcardMp4({ spec, outputMp4, canvasW, canvasH }) {
  if (!spec || !spec.path || !existsSync(spec.path)) return false;
  const durMs = Math.max(100, Math.min(5000, spec.duration_ms ?? 3000));
  const durS  = (durMs / 1000).toFixed(3);
  const isMp4 = /\.mp4$/i.test(spec.path);
  let args;
  if (isMp4) {
    args = [
      '-hide_banner', '-loglevel', 'error', '-y',
      '-t', durS, '-i', spec.path,
      '-f', 'lavfi', '-t', durS, '-i', 'anullsrc=channel_layout=stereo:sample_rate=48000',
      '-filter_complex',
        '[0:v]scale=' + canvasW + ':' + canvasH + ':force_original_aspect_ratio=decrease,' +
        'pad=' + canvasW + ':' + canvasH + ':(ow-iw)/2:(oh-ih)/2,format=yuv420p,setsar=1[v]',
      '-map', '[v]', '-map', '1:a',
      '-c:v', 'libx264', '-preset', 'fast', '-crf', '22',
      '-c:a', 'aac', '-b:a', '192k',
      '-movflags', '+faststart',
      outputMp4,
    ];
  } else {
    args = [
      '-hide_banner', '-loglevel', 'error', '-y',
      '-loop', '1', '-t', durS, '-i', spec.path,
      '-f', 'lavfi', '-t', durS, '-i', 'anullsrc=channel_layout=stereo:sample_rate=48000',
      '-filter_complex',
        '[0:v]scale=' + canvasW + ':' + canvasH + ':force_original_aspect_ratio=decrease,' +
        'pad=' + canvasW + ':' + canvasH + ':(ow-iw)/2:(oh-ih)/2,format=yuv420p,setsar=1[v]',
      '-map', '[v]', '-map', '1:a',
      '-c:v', 'libx264', '-pix_fmt', 'yuv420p', '-preset', 'fast', '-crf', '22',
      '-c:a', 'aac', '-b:a', '192k',
      '-shortest',
      '-movflags', '+faststart',
      outputMp4,
    ];
  }
  const r = spawnSync('ffmpeg', args);
  return r.status === 0;
}

async function concatMp4s(parts, outPath) {
  // ffmpeg concat demuxer needs a list file. Re-encode is safest given the
  // parts may have differing GOP structure.
  const listFile = outPath + '.concat-list.txt';
  const listBody = parts.map((p) => "file '" + p.replace(/'/g, "'\\''") + "'").join('\n') + '\n';
  writeFileSync(listFile, listBody);
  try {
    const args = [
      '-hide_banner', '-loglevel', 'error', '-y',
      '-f', 'concat', '-safe', '0',
      '-i', listFile,
      '-c:v', 'libx264', '-preset', 'fast', '-crf', '20',
      '-pix_fmt', 'yuv420p',
      '-c:a', 'aac', '-b:a', '192k',
      '-movflags', '+faststart',
      outPath,
    ];
    const r = spawnSync('ffmpeg', args);
    if (r.status !== 0) {
      const tail = (r.stderr ? r.stderr.toString().split('\n').slice(-5).join(' | ') : 'exit ' + r.status);
      throw new Error('concat failed: ' + tail);
    }
  } finally {
    try { unlinkSync(listFile); } catch {}
  }
}

async function render({ manifest }) {
  const m = JSON.parse(readFileSync(manifest, 'utf-8'));
  // Source path: explicit m.source wins, else infer from ./clips/<slug>/... convention.
  let source = m.source;
  if (!source) {
    const segs = manifest.split('/clips/');
    if (segs.length < 2) die('render: manifest path does not contain /clips/ and edit.json has no `source` field');
    source = './uploads/' + segs[1].split('/')[0] + '/source.mp4';
  }
  if (!existsSync(source)) die('source not found: ' + source);

  const audioSource = m.audio_source || (m.audio_enhancement && m.audio_enhancement.audio) || null;
  if (audioSource && !existsSync(audioSource)) die('audio_source not found: ' + audioSource);
  const audioInput = audioSource || source;

  // ADD-1: skill ordering validator. Tighten MUST run before broll, transitions,
  // and music — renderer's video concat is hard-cut; cutting across baked
  // overlays produces visible jump cuts. We block at render time rather than
  // silently producing broken output.
  if (m.cuts && (m.broll || m.transitions || m.music)) {
    die('render: skill ordering violation — tighten plan present after broll/transitions bake. Re-run tighten before broll/transitions.');
  }

  // R1: load + assert tighten plan (if any), echo warnings.
  let tightenPlan = null;
  if (m.cuts) {
    if (!existsSync(m.cuts)) die('render: cuts file not found: ' + m.cuts);
    tightenPlan = JSON.parse(readFileSync(m.cuts, 'utf-8'));
    try {
      assertPlanInvariants(tightenPlan);
    } catch (e) {
      die(e.message);
    }
    for (const w of tightenPlan.warnings || []) {
      process.stderr.write('render: tighten warning ' + w.code + ': ' + w.message + '\n');
    }
  }

  const crop = JSON.parse(readFileSync(m.crop_path, 'utf-8'));
  mkdirSync(dirname(m.output), { recursive: true });

  // ----- Pillar (i) v0.3.0: aspect profile + overlays + sidecars -----
  const renderWarnings = [];
  const canvas = chooseAspectCanvas(m.target_aspect);
  if (canvas.warning) renderWarnings.push(canvas.warning);
  // Override crop.target_w / target_h so the crop+scale chain produces the
  // chosen canvas dims. Reframe stage stays aspect-agnostic; same crop
  // center, smaller canvas. See docs/PLAN-v0.3.0.md §7 Q5.
  crop.target_w = canvas.w;
  crop.target_h = canvas.h;

  // Hook overlay — compose <output>.composed.ass next to captions, never
  // mutate the original captions.ass on disk. Layer 5 sits above the
  // Default caption layer (0).
  const tmpComposedAss = [];
  let captionsPath = m.captions && existsSync(m.captions) ? m.captions : null;
  const overlayTelemetry = { hook: null, progress_bar: null };
  if (captionsPath && m.hook_overlay && m.hook_overlay.text) {
    const composed = join(tmpdir(), 'cf-composed-ass-' + process.pid + '-' + Date.now() + '.ass');
    const original = readFileSync(captionsPath, 'utf-8');
    const hook = buildHookOverlayAss({
      text:        m.hook_overlay.text,
      end_ms:      m.hook_overlay.end_ms ?? 1800,
      position:    m.hook_overlay.position,
      fontSize:    m.hook_overlay.font_size_px,
      fillPrimary: m.hook_overlay.fill_primary,
      strokeColor: m.hook_overlay.stroke_color,
      strokePx:    m.hook_overlay.stroke_px,
      shadow:      m.hook_overlay.shadow_px,
      safeAreaPx:  m.hook_overlay.safe_area_px,
      maxChars:    m.hook_overlay.max_chars,
      canvasW:     canvas.w,
      canvasH:     canvas.h,
    });
    for (const w of hook.warnings) renderWarnings.push(w);
    // Splice the Hook style line into [V4+ Styles] (after the existing
    // Style: Default line) and append the Dialogue line to [Events].
    const composedBody = insertHookIntoAss(original, hook.ass);
    writeFileSync(composed, composedBody);
    tmpComposedAss.push(composed);
    captionsPath = composed;
    overlayTelemetry.hook = {
      burned: true,
      wrapped: hook.warnings.some((w) => w.code === 'hook_overlay_wrapped'),
      end_ms: m.hook_overlay.end_ms ?? 1800,
    };
  } else if (m.hook_overlay && m.hook_overlay.text && !captionsPath) {
    // Hook requested but no captions.ass on disk — burn a standalone ASS.
    const composed = join(tmpdir(), 'cf-hook-only-' + process.pid + '-' + Date.now() + '.ass');
    const hook = buildHookOverlayAss({
      text: m.hook_overlay.text,
      end_ms: m.hook_overlay.end_ms ?? 1800,
      position: m.hook_overlay.position,
      fontSize: m.hook_overlay.font_size_px,
      fillPrimary: m.hook_overlay.fill_primary,
      strokeColor: m.hook_overlay.stroke_color,
      strokePx: m.hook_overlay.stroke_px,
      shadow: m.hook_overlay.shadow_px,
      safeAreaPx: m.hook_overlay.safe_area_px,
      maxChars: m.hook_overlay.max_chars,
      canvasW: canvas.w,
      canvasH: canvas.h,
    });
    for (const w of hook.warnings) renderWarnings.push(w);
    writeFileSync(composed, buildStandaloneHookAss(canvas.w, canvas.h, hook.ass));
    tmpComposedAss.push(composed);
    captionsPath = composed;
    overlayTelemetry.hook = {
      burned: true,
      wrapped: hook.warnings.some((w) => w.code === 'hook_overlay_wrapped'),
      end_ms: m.hook_overlay.end_ms ?? 1800,
    };
  }

  // Progress bar — drawbox filter expression, composed into the filter graph.
  let overlayFilter = null;
  const totalMs = (m.end_ms - m.start_ms);
  if (m.progress_bar && m.progress_bar.enabled) {
    const pb = buildProgressBarDrawbox({
      enabled:    true,
      color:      m.progress_bar.color,
      heightPx:   m.progress_bar.height_px,
      position:   m.progress_bar.position,
      canvasW:    canvas.w,
      canvasH:    canvas.h,
      durationMs: totalMs,
    });
    for (const w of pb.warnings) renderWarnings.push(w);
    if (pb.filter) {
      overlayFilter = pb.filter;
      overlayTelemetry.progress_bar = {
        burned:    true,
        color:     m.progress_bar.color ?? '#ffffff',
        height_px: m.progress_bar.height_px ?? 8,
        position:  m.progress_bar.position === 'top' ? 'top' : 'bottom',
      };
    }
  }
  const deterministic = process.env.CF_RENDER_DETERMINISTIC === '1';
  const useSplice = tightenPlan && (tightenPlan.kept_segments || []).length >= 1
                                 && (tightenPlan.cuts || []).length >= 1;

  // ----- Pillar 3 v0.4.0: brand-kit overlays + endcard append -----
  //
  // Three precedence inputs for the brand kit (highest first):
  //   1. inline `m.brand_kit` — full kit object embedded in edit.json
  //   2. `m.watermark.brand_kit_ref` — pointer to a brand-kit.json
  //   3. legacy `m.watermark` (string path) — maps to logo-only kit
  // Falls back to ./uploads/<slug>/brand-kit.json then
  // ~/.clip-forge/brand-kit.json when none of the above is set.
  const brandKitTelemetry = { applied: false, source: null, assets_burned: [], warnings: [] };
  let brandKitChain = null;
  let brandKitFinalLabel = null;
  let brandKitExtraInputs = [];
  let brandKitEndcardSpec = null;
  {
    const projectKitPath = m.slug ? join('./uploads', m.slug, 'brand-kit.json') : null;
    const globalKitPath  = join(process.env.HOME || homedir(), '.clip-forge', 'brand-kit.json');
    const resolved = resolveKitForEdit(m, { globalPath: globalKitPath, projectPath: projectKitPath });
    for (const w of resolved.warnings) brandKitTelemetry.warnings.push(w);
    if (resolved.applied) {
      const inputIndexOffset = (audioSource ? 2 : 1);  // 0=source, 1=audio (if set)
      const composed = composeBrandKitFilter({
        brand:           resolved.kit,
        canvasW:         canvas.w,
        canvasH:         canvas.h,
        inputIndexOffset,
        startLabel:      useSplice ? 'vconcat' : 'vcrop',
        librsvgAvailable: probeLibrsvg(),
      });
      for (const w of composed.warnings) brandKitTelemetry.warnings.push(w);
      if (composed.chain) {
        brandKitChain       = composed.chain;
        brandKitFinalLabel  = composed.finalLabel;
        brandKitExtraInputs = composed.extraInputs;
        brandKitTelemetry.applied       = true;
        brandKitTelemetry.source        = resolved.source;
        brandKitTelemetry.assets_burned = composed.assetsBurned.slice();
      }
      if (resolved.kit.assets && resolved.kit.assets.endcard) {
        brandKitEndcardSpec = resolved.kit.assets.endcard;
        brandKitTelemetry.applied = true;
        if (!brandKitTelemetry.source) brandKitTelemetry.source = resolved.source;
        if (!brandKitTelemetry.assets_burned.includes('endcard')) {
          brandKitTelemetry.assets_burned.push('endcard');
        }
      }
    }
    // Mirror brand-kit warnings into the top-level render_warnings, but
    // strip the `asset` sub-field — the top-level schema is `{code, message}`
    // only (additionalProperties:false). The `asset` field stays available
    // inside `brand_kit.warnings` where the schema allows it.
    for (const w of brandKitTelemetry.warnings) {
      renderWarnings.push({ code: w.code, message: w.message || '' });
    }
  }

  let plan;
  if (useSplice) {
    plan = planSpliceArgs({
      crop, source, output: m.output,
      startMs: m.start_ms, endMs: m.end_ms,
      captionsPath, quality: m.quality,
      tightenPlan,
      hasAudio: hasAudioStream(audioInput),
      deterministic,
      audioSource: audioInput,
      overlayFilter,
      brandKitChain, brandKitFinalLabel, brandKitExtraInputs,
    });
    // ADD-3: filter graph size guard (uses the larger of the two graphs).
    if (plan.filterComplex.length > GRAPH_SIZE_WARN_BYTES) {
      process.stderr.write('render: filter graph length ' + plan.filterComplex.length +
        ' bytes, approaching ffmpeg default limit (~10KB). Consider --segment-batch if added.\n');
    }
    process.stdout.write(JSON.stringify({
      event: 'plan', mode: 'splice',
      kept: plan.keptCount, junctions: plan.junctionCount,
      xfade_s: JUNCTION_XFADE_S, pad_dur_s: plan.padDurS,
      filter_complex_bytes: plan.filterComplex.length,
      passes: plan.passes.length,
      encoder: plan.encoder, deterministic,
    }) + '\n');
  } else {
    const cropPlan = planCropArgs({
      crop, source, output: m.output,
      startMs: m.start_ms, endMs: m.end_ms,
      captionsPath, quality: m.quality,
      audioSource,
      overlayFilter,
      deterministic,
      brandKitChain, brandKitFinalLabel, brandKitExtraInputs,
    });
    plan = { passes: [{ label: 'crop', ...cropPlan }], tmpFiles: cropPlan.scriptFile ? [cropPlan.scriptFile] : [], mode: cropPlan.mode, encoder: cropPlan.encoder };
    process.stdout.write(JSON.stringify({
      event: 'plan', mode: cropPlan.mode, keyframes: cropPlan.keyframeCount, expr_bytes: cropPlan.byteSize,
      encoder: cropPlan.encoder,
    }) + '\n');
  }

  let lastPct = -1;
  const total = (m.end_ms - m.start_ms);
  const passWalls = [];
  try {
    for (const pass of plan.passes) {
      lastPct = -1; // restart progress per pass
      await runFfmpegPlan(pass, {
        onProgress: ({ out_ms }) => {
          const pct = Math.min(99, Math.floor((out_ms / total) * 100));
          if (pct > lastPct) {
            lastPct = pct;
            process.stdout.write(JSON.stringify({ event: 'progress', pass: pass.label, pct }) + '\n');
          }
        },
      });
      passWalls.push({ name: pass.label, wall_ms: pass.wallMs || 0 });
    }

    // R6: zero-byte output guard.
    if (!existsSync(m.output) || statSync(m.output).size === 0) {
      try { unlinkSync(m.output); } catch {}
      die('render: produced zero-byte output (no file left on disk)');
    }

    // ----- v0.4.0 pillar 2: prepend / append stingers (hook/outro TTS) -----
    // ttsProviderUsed + ttsNondeterministic are declared at the render()
    // function scope (see below at the report-build call site) — the
    // existing v0.3.0 callers don't carry them, so they default to
    // null/false. v0.4.0 paths populate them inside this block.
    var ttsProviderUsed = null;
    var ttsNondeterministic = false;
    const stingerWarnings = [];
    if (m.prepend_audio || m.append_audio) {
      const outDir = dirname(m.output);
      const preRes  = await resolveStingerAudio(m.prepend_audio, { outputDir: outDir, kind: 'prepend' });
      const postRes = await resolveStingerAudio(m.append_audio,  { outputDir: outDir, kind: 'append'  });
      if (preRes.fallback_used)  stingerWarnings.push({ code: 'prepend_audio_skipped', message: preRes.fallback_reason });
      if (postRes.fallback_used) stingerWarnings.push({ code: 'append_audio_skipped',  message: postRes.fallback_reason });
      if (preRes.was_tts || postRes.was_tts) {
        ttsNondeterministic = true;
        ttsProviderUsed = preRes.provider_used || postRes.provider_used || null;
      }
      const parts = [];
      const tmpStingers = [];
      if (preRes.audio_path) {
        const stingerMp4 = join(tmpdir(), 'cf-prepend-' + process.pid + '-' + Date.now() + '.mp4');
        const ok = await buildStingerMp4({ audioPath: preRes.audio_path, outputMp4: stingerMp4,
                                             canvasW: canvas.w, canvasH: canvas.h });
        if (ok) { parts.push(stingerMp4); tmpStingers.push(stingerMp4); }
        else stingerWarnings.push({ code: 'prepend_stinger_build_failed', message: 'ffmpeg failed to build prepend stinger' });
      }
      parts.push(m.output);
      if (postRes.audio_path) {
        const stingerMp4 = join(tmpdir(), 'cf-append-' + process.pid + '-' + Date.now() + '.mp4');
        const ok = await buildStingerMp4({ audioPath: postRes.audio_path, outputMp4: stingerMp4,
                                             canvasW: canvas.w, canvasH: canvas.h });
        if (ok) { parts.push(stingerMp4); tmpStingers.push(stingerMp4); }
        else stingerWarnings.push({ code: 'append_stinger_build_failed', message: 'ffmpeg failed to build append stinger' });
      }
      if (parts.length > 1) {
        const combined = m.output + '.with-stingers.mp4';
        try {
          await concatMp4s(parts, combined);
          renameSync(combined, m.output);
        } catch (e) {
          stingerWarnings.push({ code: 'stinger_concat_failed', message: e.message });
          try { unlinkSync(combined); } catch {}
        }
      }
      for (const f of tmpStingers) { try { unlinkSync(f); } catch {} }
      for (const w of stingerWarnings) renderWarnings.push(w);
    }

    // ----- v0.4.0 pillar 3: brand-kit endcard append -----
    if (brandKitEndcardSpec && brandKitEndcardSpec.path && existsSync(brandKitEndcardSpec.path)) {
      const endcardMp4 = join(tmpdir(), 'cf-endcard-' + process.pid + '-' + Date.now() + '.mp4');
      const ok = await buildEndcardMp4({
        spec: brandKitEndcardSpec, outputMp4: endcardMp4,
        canvasW: canvas.w, canvasH: canvas.h,
      });
      if (ok) {
        const combined = m.output + '.with-endcard.mp4';
        try {
          await concatMp4s([m.output, endcardMp4], combined);
          renameSync(combined, m.output);
        } catch (e) {
          renderWarnings.push({ code: 'endcard_concat_failed', message: e.message });
          try { unlinkSync(combined); } catch {}
        }
        try { unlinkSync(endcardMp4); } catch {}
      } else {
        renderWarnings.push({ code: 'endcard_build_failed',
                              message: 'ffmpeg failed to materialise endcard at ' + brandKitEndcardSpec.path });
      }
    }

    // ----- emit VTT + SRT sidecars (pillar (i) — best-effort) -----
    const sidecars = emitSidecars({
      captionsJsonPath: m.captions_json,
      captionsAssPath:  m.captions,
      outputPath:       m.output,
    });

    // ----- emit render_report.json -----
    const reportPath = join(dirname(m.output), 'render_report.json');
    const renderMode = useSplice ? 'splice' : 'passthrough';
    if (useSplice && plan.filterComplex.length > GRAPH_SIZE_WARN_BYTES) {
      renderWarnings.push({
        code: 'filter_graph_length_near_limit',
        message: `filter graph ${plan.filterComplex.length} bytes, approaching ffmpeg ~10KB limit`,
      });
    }

    let junctions = [];
    let tightenSection = null;
    if (useSplice && hasAudioStream(audioInput)) {
      const outPcmPath = join(tmpdir(), 'cf-out-pcm-' + process.pid + '-' + Date.now() + '.raw');
      const srcPcmPath = join(tmpdir(), 'cf-src-pcm-' + process.pid + '-' + Date.now() + '.raw');
      try {
        extractMonoPcm({ source: m.output, output: outPcmPath });
        extractMonoPcm({ source: audioInput, output: srcPcmPath, startMs: m.start_ms, endMs: m.end_ms });
        const outputPcm = readPcm(outPcmPath);
        const sourcePcm = readPcm(srcPcmPath);
        junctions = computeJunctionMetrics({
          outputPcm, sourcePcm,
          basisStartMs: tightenPlan.basis_start_ms,
          keptSegments: tightenPlan.kept_segments,
          xfadeS: JUNCTION_XFADE_S,
        });
      } finally {
        try { unlinkSync(outPcmPath); } catch {}
        try { unlinkSync(srcPcmPath); } catch {}
      }
    }
    if (useSplice) {
      tightenSection = {
        plan_path: m.cuts,
        kept_segments_count: tightenPlan.kept_segments.length,
        cuts_count: tightenPlan.cuts.length,
        saved_ms: tightenPlan.saved_ms,
        warnings_from_plan: tightenPlan.warnings || [],
      };
    }

    // Probe output durations for the report.
    const probeAudio = spawnSync('ffprobe', ['-v','error','-select_streams','a','-show_entries','stream=duration','-of','csv=p=0', m.output], { encoding: 'utf-8' });
    const probeVideo = spawnSync('ffprobe', ['-v','error','-select_streams','v','-show_entries','stream=duration','-of','csv=p=0', m.output], { encoding: 'utf-8' });
    const audioDurMs = probeAudio.status === 0 && probeAudio.stdout.trim() ? Math.round(parseFloat(probeAudio.stdout.trim()) * 1000) : 0;
    const videoDurMs = probeVideo.status === 0 && probeVideo.stdout.trim() ? Math.round(parseFloat(probeVideo.stdout.trim()) * 1000) : 0;

    // Mode-aware AV drift warnings (ACTION 13/14).
    const outDur  = videoDurMs || (useSplice ? tightenPlan.output_duration_ms : total);
    const avDrift = outDur - audioDurMs;
    if (renderMode === 'splice') {
      if (avDrift < -50) {
        renderWarnings.push({
          code: 'av_drift_audio_overhang_excessive',
          message: `audio is ${-avDrift} ms longer than video, exceeding 50 ms threshold. Splice math may be emitting tail silence beyond expected duration.`,
        });
      } else if (avDrift > 50) {
        renderWarnings.push({
          code: 'av_drift_video_longer_in_splice',
          message: `video is ${avDrift} ms longer than audio in splice mode. Splice math may have dropped audio frames; investigate AAC encoder buffer flush.`,
        });
      }
    } else {
      if (Math.abs(avDrift) > 10) {
        renderWarnings.push({
          code: 'av_drift_unexpected_passthrough',
          message: `passthrough render has ${avDrift} ms A/V drift, exceeding 10 ms tolerance. Possible muxer issue or input stream sync defect.`,
        });
      }
    }

    // v0.4.0 pillar 2 — populate ai_costs from render_manifest.json (if any)
    // and dub_languages from edit.json.dub or sibling dub_report files.
    let aiCostsSnapshot = null;
    let dubLanguages = [];
    if (m.slug || m.render_manifest) {
      const mfPath = m.render_manifest || (m.slug ? join('./renders', m.slug, 'render_manifest.json') : null);
      if (mfPath && existsSync(mfPath)) {
        try {
          const mf = loadManifest(mfPath, { slug: m.slug });
          aiCostsSnapshot = snapshotForReport(mf);
        } catch { /* best-effort */ }
      }
    }
    if (m.dub && m.dub.target_lang) dubLanguages.push(m.dub.target_lang);
    if (Array.isArray(m.dub_languages)) {
      for (const l of m.dub_languages) if (!dubLanguages.includes(l)) dubLanguages.push(l);
    }

    const report = buildRenderReport({
      clipId: m.clip_id ?? null,
      renderMode,
      inputDurationMs: total,
      outputDurationMs: outDur,
      audioDurationMs: audioDurMs,
      encoder: plan.encoder,
      deterministic,
      passes: passWalls,
      filterComplexBytes: useSplice ? plan.filterComplex.length : 0,
      junctionXfadeS: JUNCTION_XFADE_S,
      tighten: tightenSection,
      junctions,
      warnings: renderWarnings,
      targetAspect: canvas.name,
      overlays: (overlayTelemetry.hook || overlayTelemetry.progress_bar) ? overlayTelemetry : null,
      sidecars,
      aiCosts: aiCostsSnapshot,
      ttsProviderUsed,
      ttsNondeterministic,
      dubLanguages,
      brandKit: brandKitTelemetry.applied ? brandKitTelemetry : null,
    });
    writeRenderReport(report, reportPath);

    process.stdout.write(JSON.stringify({ event: 'done', path: m.output, report_path: reportPath }) + '\n');
  } finally {
    for (const f of (plan.tmpFiles || [])) { try { unlinkSync(f); } catch {} }
    for (const f of tmpComposedAss)        { try { unlinkSync(f); } catch {} }
  }
}

// Stand-alone crop-animation renderer (no captions / b-roll / music). Useful
// for testing the crop pipeline in isolation. Reads a crop_path.json and
// produces output mp4 directly.
async function reframeAnimated(flags) {
  const cropPath = flags['crop-path'];
  const source   = flags.source;
  const output   = flags.output;
  if (!cropPath || !source || !output) {
    die('usage: cf-ffmpeg reframe-animated --crop-path <p> --source <s> --output <o> [--start-ms N --end-ms N]');
  }
  if (!existsSync(source))   die('source not found: ' + source);
  if (!existsSync(cropPath)) die('crop-path not found: ' + cropPath);

  const crop = JSON.parse(readFileSync(cropPath, 'utf-8'));
  mkdirSync(dirname(resolvePath(output)), { recursive: true });

  const plan = planCropArgs({
    crop, source, output,
    startMs: flags['start-ms'] != null ? parseInt(flags['start-ms'], 10) : undefined,
    endMs:   flags['end-ms']   != null ? parseInt(flags['end-ms'],   10) : undefined,
    captionsPath: null,
    quality: flags.quality,
  });

  process.stdout.write(JSON.stringify({
    event: 'plan', mode: plan.mode, keyframes: plan.keyframeCount, expr_bytes: plan.byteSize,
    encoder: plan.encoder,
  }) + '\n');

  try {
    await runFfmpegPlan(plan, {
      onProgress: ({ out_ms }) => {
        process.stdout.write(JSON.stringify({ event: 'progress', out_ms }) + '\n');
      },
    });
  } finally {
    if (plan.scriptFile) { try { unlinkSync(plan.scriptFile); } catch {} }
  }
  process.stdout.write(JSON.stringify({ event: 'done', path: output, mode: plan.mode }) + '\n');
}

// ----- argv routing -----
const [, , sub, ...rest] = process.argv;
const parseFlags = (xs) => {
  const out = {};
  for (let i = 0; i < xs.length; i++) {
    if (xs[i].startsWith('--')) { out[xs[i].slice(2)] = xs[i + 1]; i++; }
  }
  return out;
};

(async () => {
  try {
    if (sub === 'probe')         await probe(rest[0]);
    else if (sub === 'ingest')   await ingest(rest[0], rest[1]);
    else if (sub === 'render')   await render(parseFlags(rest));
    else if (sub === 'reframe-animated') await reframeAnimated(parseFlags(rest));
    else if (sub === 'caption-burn') await captionBurn(rest[0], rest[1], rest[2]);
    else if (sub === 'music-mix')    await musicMix(rest[0], rest[1], rest[2], rest.includes('--duck'));
    else if (sub === 'watermark')    await watermark(rest[0], rest[1], rest[2]);
    else die('unknown subcommand: ' + (sub || '(none)') + '\n' +
             'try: probe|ingest|render|caption-burn|music-mix|watermark');
  } catch (e) {
    die(e.message, 1);
  }
})();
