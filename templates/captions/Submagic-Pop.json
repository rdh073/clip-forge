{
  "name": "Submagic-Pop",
  "inspired_by": "Submagic's animated word-by-word reveal",
  "font": {
    "family": "Inter",
    "fallback": ["Geist", "SF Pro", "Helvetica Neue"],
    "weight": 800,
    "size_px": 72,
    "letter_spacing_px": 0
  },
  "colors": {
    "fill": "#ffffff",
    "stroke": "#000000",
    "highlight": "#ff5cff",
    "highlight_fill": "#ffffff"
  },
  "outline": {
    "width_px": 4,
    "shadow_px": 2
  },
  "position": {
    "alignment": "center",
    "margin_v_px": 0,
    "max_lines": 1
  },
  "animation": {
    "enter": "word_by_word",
    "enter_duration_ms": 100,
    "exit": "cut",
    "highlight": "color_swap"
  },
  "emoji_strategy": "auto",
  "words_per_line": 4,
  "hook_overlay": {
    "font_size_px": 88,
    "stroke_px": 6,
    "fill_primary": "$brand.primary",
    "stroke_color": "#000000",
    "shadow_px": 2,
    "default_position": "upper-third",
    "max_chars": 36
  }
}
