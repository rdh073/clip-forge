{
  "name": "Karaoke",
  "inspired_by": "Classic karaoke fill-as-you-speak",
  "font": {
    "family": "Inter",
    "fallback": ["Geist", "Arial"],
    "weight": 700,
    "size_px": 68,
    "letter_spacing_px": 0
  },
  "colors": {
    "fill": "#9aa3b2",
    "stroke": "#000000",
    "highlight": "#ffffff",
    "highlight_fill": "#ff3366"
  },
  "outline": {
    "width_px": 4,
    "shadow_px": 2
  },
  "position": {
    "alignment": "bottom_center",
    "margin_v_px": 240,
    "max_lines": 2
  },
  "animation": {
    "enter": "fade",
    "enter_duration_ms": 60,
    "exit": "fade",
    "highlight": "progressive_fill"
  },
  "emoji_strategy": "off",
  "words_per_line": 6
}
