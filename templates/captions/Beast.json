{
  "name": "Beast",
  "inspired_by": "MrBeast-style burnt-in captions",
  "font": {
    "family": "Anton",
    "fallback": ["Bebas Neue", "Impact", "Arial Black"],
    "weight": 900,
    "size_px": 84,
    "letter_spacing_px": 2
  },
  "colors": {
    "fill": "#ffffff",
    "stroke": "#000000",
    "highlight": "#ffe600",
    "highlight_fill": "#000000"
  },
  "outline": {
    "width_px": 8,
    "shadow_px": 4
  },
  "position": {
    "alignment": "bottom_center",
    "margin_v_px": 280,
    "max_lines": 2
  },
  "animation": {
    "enter": "pop",
    "enter_duration_ms": 80,
    "exit": "cut",
    "highlight": "scale_115_yellow"
  },
  "emoji_strategy": "sentence_end",
  "words_per_line": 3,
  "hook_overlay": {
    "font_size_px": 104,
    "stroke_px": 8,
    "fill_primary": "$brand.primary",
    "stroke_color": "#000000",
    "shadow_px": 4,
    "default_position": "upper-third",
    "max_chars": 28
  }
}
